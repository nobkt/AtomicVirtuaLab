SystemName	siesta
SystemLabel	siesta

%block ExternalElectricField
0.0 -0.0514220632 0.0 V/Ang
%endblock ExternalElectricField
MaxSCFIterations	2000
SCF.DM.Tolerance	1e-08
SCFMustConverge	False
SolutionMethod	diagon
WriteCoorCerius	True
WriteCoorStep	True
WriteCoorXmol	True
WriteForces	True
WriteMDHistory	True
WriteMDXmol	True
siesta2Wannier90.WriteAmn	True
siesta2Wannier90.WriteEig	True
siesta2Wannier90.WriteMmn	True
siesta2Wannier90.WriteUnk	False

Spin     	non-polarized
XC.functional	GGA
XC.authors	PBE

MeshCutoff	680.2846506091811	eV
PAO.EnergyShift	0.1	eV

NumberOfSpecies	2
NumberOfAtoms	3
%block ChemicalSpecieslabel
    1 1 H.gga.1
    2 8 O.gga.2
%endblock ChemicalSpecieslabel

%block PAO.BasisSizes
    H.gga.1	SZ
    O.gga.2	SZ
%endblock PAO.BasisSizes


LatticeConstant	1.0 Ang
%block LatticeVectors
    30.000000000000000     0.000000000000000     0.000000000000000 
    0.000000000000000     30.000000000000000     0.000000000000000 
    0.000000000000000     0.000000000000000     30.000000000000000 
%endblock LatticeVectors


AtomicCoordinatesFormat  Ang
%block AtomicCoordinatesAndAtomicSpecies
    14.579389709     14.149197036     14.830272606 1
    14.401789709     15.733397036     15.181272606 1
    15.064189709     15.007397036     14.999272606 2
%endblock AtomicCoordinatesAndAtomicSpecies

%block DM.InitSpin
%endblock DM.InitSpin

DM.UseSaveDM	True

Siesta2Wannier90.NumberOfBands   4
